<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane id="AnchorPane" prefHeight="400.0" prefWidth="384.0" styleClass="mainFxmlClass" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/26" fx:controller="com.franRR.librarymanager.controller.LoginViewController">
    <stylesheets>
        <URL value="@/css/login-view.css" />
    </stylesheets>
   <children>
      <VBox alignment="CENTER" layoutX="250.0" layoutY="56.0" prefHeight="400.0" prefWidth="398.0" spacing="12.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <Label text="Inicio de sesión">
               <font>
                  <Font name="System Bold" size="30.0" />
               </font>
            </Label>
            <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="303.0" spacing="5.0">
               <children>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Nombre de usuario:">
                     <VBox.margin>
                        <Insets right="75.0" top="20.0" />
                     </VBox.margin>
                  </Text>
                  <TextField fx:id="userNameField" maxWidth="180.0" minWidth="180.0" prefWidth="180.0" promptText="Introducir nombre de usuario">
                     <VBox.margin>
                        <Insets bottom="15.0" />
                     </VBox.margin>
                  </TextField>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Contraseña:">
                     <VBox.margin>
                        <Insets right="117.0" />
                     </VBox.margin>
                  </Text>
                  <TextField fx:id="passwdUserField" maxWidth="180.0" minWidth="180.0" prefWidth="180.0" promptText="Introducir contraseña" />
               </children>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </VBox>
            <Text fx:id="registerButton" onMouseClicked="#registerUser" strokeType="OUTSIDE" strokeWidth="0.0" text="Resgistrarse" />
            <Button fx:id="loginBtn" mnemonicParsing="false" onAction="#login" text="Iniciar sesión" />
         </children>
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
         </padding>
      </VBox>
   </children>
</AnchorPane>
